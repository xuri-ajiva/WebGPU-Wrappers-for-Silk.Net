	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Hexa.NET.ImGui" />
		<PackageReference Include="Hexa.NET.ImGui.Backends.SDL3" />
		<PackageReference Include="Hexa.NET.SDL3" />
		<PackageReference Include="Hexa.NET.Utilities" />
		<PackageReference Include="Silk.NET.WebGPU" />
	</ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="..\Silk.NET.WebGPU.Safe\Silk.NET.WebGPU.Safe.csproj" />
	</ItemGroup>
</Project>
